procedure negate_via_loop(int x)
    if x > 0 then
        local int t = x
        from t = x do
            skip
        loop
            x -= 1
            x -= 1
            t -= 1
        until t = 0
        delocal int t = 0
    else
        local int t = x
        from t = x do
            skip
        loop
            x += 1
            x += 1
            t += 1
        until t = 0
        delocal int t = 0
    fi x < 0