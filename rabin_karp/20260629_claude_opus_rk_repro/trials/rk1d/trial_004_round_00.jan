procedure whash(int A[], int base, int q, int start, int m, int h)
  local int U = 0
    local int pwr = 1
      local int j = 0
        from j = 0 do
          U += A[start + (m - 1 - j)] * pwr
          pwr *= base
          j += 1
        loop
          skip
        until j = m
        h += U % q
        from j = m do
          j -= 1
          pwr /= base
          U -= A[start + (m - 1 - j)] * pwr
        loop
          skip
        until j = 0
      delocal int j = 0
    delocal int pwr = 1
  delocal int U = 0

procedure countdiff(int T[], int P[], int s, int m, int diff)
  local int j = 0
    from j = 0 do
      if T[s + j] != P[j] then
        diff += 1
      else
        skip
      fi T[s + j] != P[j]
      j += 1
    loop
      skip
    until j = m
  delocal int j = m

procedure rabinkarp1(int T[], int n, int P[], int m, int d, int q, stack r)
  local int ph = 0
    call whash(P, d, q, 0, m, ph)
    local int s = 0
      from s = 0 do
        local int hh = 0
          call whash(T, d, q, s, m, hh)
          if hh = ph then
            local int diff = 0
              call countdiff(T, P, s, m, diff)
              if diff = 0 then
                local int v = 0
                  v += s
                  push(v, r)
                delocal int v = 0
              else
                skip
              fi diff = 0
              uncall countdiff(T, P, s, m, diff)
            delocal int diff = 0
          else
            skip
          fi hh = ph
          uncall whash(T, d, q, s, m, hh)
        delocal int hh = 0
        s += 1
      loop
        skip
      until s = n - m + 1
    delocal int s = n - m + 1
    uncall whash(P, d, q, 0, m, ph)
  delocal int ph = 0