procedure cubehash(int A[][][], int bi, int bj, int bk, int m, int d, int h)
  local int i = 0
  from i = 0 do
    local int j = 0
    from j = 0 do
      local int k = 0
      from k = 0 do
        h *= d
        h += A[bi+i][bj+j][bk+k]
      loop
        k += 1
      until k = m
      delocal int k = m
    loop
      j += 1
    until j = m
    delocal int j = m
  loop
    i += 1
  until i = m
  delocal int i = m

procedure countmis(int T[][][], int bi, int bj, int bk, int P[][][], int m, int c)
  local int i = 0
  from i = 0 do
    local int j = 0
    from j = 0 do
      local int k = 0
      from k = 0 do
        c += (T[bi+i][bj+j][bk+k] != P[i][j][k])
      loop
        k += 1
      until k = m
      delocal int k = m
    loop
      j += 1
    until j = m
    delocal int j = m
  loop
    i += 1
  until i = m
  delocal int i = m

procedure rabinkarp3(int T[][][], int n, int P[][][], int m, int d, int q, stack r)
  local int hp = 0
  call cubehash(P, 0, 0, 0, m, d, hp)
  local int w = n - m + 1
  local int s1 = 0
  from s1 = 0 do
    local int s2 = 0
    from s2 = 0 do
      local int s3 = 0
      from s3 = 0 do
        local int hw = 0
        call cubehash(T, s1, s2, s3, m, d, hw)
        local int diff = (hw % q) - (hp % q)
        if diff = 0 then
          local int mism = 0
          call countmis(T, s1, s2, s3, P, m, mism)
          if mism = 0 then
            local int p1 = 0
            p1 += s1
            push(p1, r)
            delocal int p1 = 0
            local int p2 = 0
            p2 += s2
            push(p2, r)
            delocal int p2 = 0
            local int p3 = 0
            p3 += s3
            push(p3, r)
            delocal int p3 = 0
          else
            skip
          fi mism = 0
          uncall countmis(T, s1, s2, s3, P, m, mism)
          delocal int mism = 0
        else
          skip
        fi diff = 0
        delocal int diff = (hw % q) - (hp % q)
        uncall cubehash(T, s1, s2, s3, m, d, hw)
        delocal int hw = 0
      loop
        s3 += 1
      until s3 = w
      delocal int s3 = w
    loop
      s2 += 1
    until s2 = w
    delocal int s2 = w
  loop
    s1 += 1
  until s1 = w
  delocal int s1 = w
  delocal int w = n - m + 1
  uncall cubehash(P, 0, 0, 0, m, d, hp)
  delocal int hp = 0