procedure rkpow(int PW[], int rad, int m, int q)
    PW[0] += 1
    local int t = 0
    from t = 0 do
        local int x = (PW[t] * rad) % q
        PW[t + 1] += x
        delocal int x = PW[t + 1]
        t += 1
    until t = m
    delocal int t = m

procedure rkhash1(int A[][][], int na, int w, int m, int d, int q, int PD[], int H[])
    local int i = 0
    from i = 0 do
        local int j = 0
        from j = 0 do
            local int k = 0
            from k = 0 do
                local int x = ((A[i][j][k] % q) * PD[m - 1 - k]) % q
                H[(i * na + j) * w] += x
                delocal int x = ((A[i][j][k] % q) * PD[m - 1 - k]) % q
                k += 1
            until k = m
            delocal int k = m
            if w > 1 then
                local int s = 0
                from s = 0 do
                    local int x = (((H[(i * na + j) * w + s] % q) + q - (((A[i][j][s] % q) * PD[m - 1]) % q)) * (d % q) + (A[i][j][s + m] % q)) % q
                    H[(i * na + j) * w + s + 1] += x
                    delocal int x = H[(i * na + j) * w + s + 1]
                    s += 1
                until s = w - 1
                delocal int s = w - 1
            else
                skip
            fi w > 1
            j += 1
        until j = na
        delocal int j = na
        i += 1
    until i = na
    delocal int i = na

procedure rkhash2(int H1[], int na, int w, int m, int q, int P2[], int H2[])
    local int i = 0
    from i = 0 do
        local int s3 = 0
        from s3 = 0 do
            local int j = 0
            from j = 0 do
                local int x = ((H1[(i * na + j) * w + s3] % q) * P2[m - 1 - j]) % q
                H2[(i * w) * w + s3] += x
                delocal int x = ((H1[(i * na + j) * w + s3] % q) * P2[m - 1 - j]) % q
                j += 1
            until j = m
            delocal int j = m
            if w > 1 then
                local int s = 0
                from s = 0 do
                    local int x = (((H2[(i * w + s) * w + s3] % q) + q - (((H1[(i * na + s) * w + s3] % q) * P2[m - 1]) % q)) * P2[1] + (H1[(i * na + s + m) * w + s3] % q)) % q
                    H2[(i * w + s + 1) * w + s3] += x
                    delocal int x = H2[(i * w + s + 1) * w + s3]
                    s += 1
                until s = w - 1
                delocal int s = w - 1
            else
                skip
            fi w > 1
            s3 += 1
        until s3 = w
        delocal int s3 = w
        i += 1
    until i = na
    delocal int i = na

procedure rkhash3(int H2[], int w, int m, int q, int P3[], int H3[])
    local int s2 = 0
    from s2 = 0 do
        local int s3 = 0
        from s3 = 0 do
            local int i = 0
            from i = 0 do
                local int x = ((H2[(i * w + s2) * w + s3] % q) * P3[m - 1 - i]) % q
                H3[s2 * w + s3] += x
                delocal int x = ((H2[(i * w + s2) * w + s3] % q) * P3[m - 1 - i]) % q
                i += 1
            until i = m
            delocal int i = m
            if w > 1 then
                local int s = 0
                from s = 0 do
                    local int x = (((H3[(s * w + s2) * w + s3] % q) + q - (((H2[(s * w + s2) * w + s3] % q) * P3[m - 1]) % q)) * P3[1] + (H2[((s + m) * w + s2) * w + s3] % q)) % q
                    H3[((s + 1) * w + s2) * w + s3] += x
                    delocal int x = H3[((s + 1) * w + s2) * w + s3]
                    s += 1
                until s = w - 1
                delocal int s = w - 1
            else
                skip
            fi w > 1
            s3 += 1
        until s3 = w
        delocal int s3 = w
        s2 += 1
    until s2 = w
    delocal int s2 = w

procedure rkcmp(int T[][][], int P[][][], int s1, int s2, int s3, int m, int df)
    local int a = 0
    from a = 0 do
        local int b = 0
        from b = 0 do
            local int c = 0
            from c = 0 do
                if T[s1 + a][s2 + b][s3 + c] != P[a][b][c] then
                    df += 1
                else
                    skip
                fi T[s1 + a][s2 + b][s3 + c] != P[a][b][c]
                c += 1
            until c = m
            delocal int c = m
            b += 1
        until b = m
        delocal int b = m
        a += 1
    until a = m
    delocal int a = m

procedure rabinkarp3(int T[][][], int n, int P[][][], int m, int d, int q, stack r)
    local int PD[m + 1] = 0, int P2[m + 1] = 0, int P3[m + 1] = 0, int H1[n * n * (n - m + 1)] = 0, int H2[n * (n - m + 1) * (n - m + 1)] = 0, int H3[(n - m + 1) * (n - m + 1) * (n - m + 1)] = 0, int G1[m * m] = 0, int G2[m] = 0, int G3[1] = 0
        call rkpow(PD, d % q, m, q)
        call rkpow(P2, PD[m], m, q)
        call rkpow(P3, P2[m], m, q)
        call rkhash1(T, n, n - m + 1, m, d, q, PD, H1)
        call rkhash2(H1, n, n - m + 1, m, q, P2, H2)
        call rkhash3(H2, n - m + 1, m, q, P3, H3)
        call rkhash1(P, m, 1, m, d, q, PD, G1)
        call rkhash2(G1, m, 1, m, q, P2, G2)
        call rkhash3(G2, 1, m, q, P3, G3)
        local int s1 = 0
        from s1 = 0 do
            local int s2 = 0
            from s2 = 0 do
                local int s3 = 0
                from s3 = 0 do
                    if (H3[(s1 * (n - m + 1) + s2) * (n - m + 1) + s3] % q) = (G3[0] % q) then
                        local int df = 0
                        call rkcmp(T, P, s1, s2, s3, m, df)
                        if df = 0 then
                            local int w = 0
                            w += s1
                            push(w, r)
                            w += s2
                            push(w, r)
                            w += s3
                            push(w, r)
                            delocal int w = 0
                        else
                            skip
                        fi df = 0
                        uncall rkcmp(T, P, s1, s2, s3, m, df)
                        delocal int df = 0
                    else
                        skip
                    fi (H3[(s1 * (n - m + 1) + s2) * (n - m + 1) + s3] % q) = (G3[0] % q)
                    s3 += 1
                until s3 = n - m + 1
                delocal int s3 = n - m + 1
                s2 += 1
            until s2 = n - m + 1
            delocal int s2 = n - m + 1
            s1 += 1
        until s1 = n - m + 1
        delocal int s1 = n - m + 1
        uncall rkhash3(G2, 1, m, q, P3, G3)
        uncall rkhash2(G1, m, 1, m, q, P2, G2)
        uncall rkhash1(P, m, 1, m, d, q, PD, G1)
        uncall rkhash3(H2, n - m + 1, m, q, P3, H3)
        uncall rkhash2(H1, n, n - m + 1, m, q, P2, H2)
        uncall rkhash1(T, n, n - m + 1, m, d, q, PD, H1)
        uncall rkpow(P3, P2[m], m, q)
        uncall rkpow(P2, PD[m], m, q)
        uncall rkpow(PD, d % q, m, q)
    delocal int PD[m + 1] = 0, int P2[m + 1] = 0, int P3[m + 1] = 0, int H1[n * n * (n - m + 1)] = 0, int H2[n * (n - m + 1) * (n - m + 1)] = 0, int H3[(n - m + 1) * (n - m + 1) * (n - m + 1)] = 0, int G1[m * m] = 0, int G2[m] = 0, int G3[1] = 0